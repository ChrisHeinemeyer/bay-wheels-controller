#!/bin/sh
# Only run if src/ has changes between local and remote

run_build=0
while read local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_ref" ] && continue
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  # New branch (no remote yet) - run the build
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    run_build=1
    break
  fi

  # Check if src/ has changes
  if ! git diff --name-only --quiet "$remote_sha" "$local_sha" -- src/ 2>/dev/null; then
    run_build=1
    break
  fi
done

if [ "$run_build" = 1 ]; then
  cargo build --release
fi
